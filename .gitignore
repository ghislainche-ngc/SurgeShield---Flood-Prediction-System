# ─── Secrets / environment ───────────────────────────────────────────
# Never commit credentials (Clerk keys, Convex URLs, ML_API_URL, etc.)
.env
.env.*
!.env.example
*.pem
/.clerk/

# ─── Node / Next.js (frontend) ───────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.next/
out/
build/
/coverage
*.tsbuildinfo
next-env.d.ts
.vercel

# ─── Python / ML pipeline (ml-api) ───────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
*.egg-info/
.ipynb_checkpoints/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ─── Logs & debug ────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Agent / local tooling ───────────────────────────────────────────
.claude-flow/
.claude/
.playwright-mcp/

# Stray local screenshots at repo root (Playwright captures, scratch images).
# Design renders live under designs/ and are committed normally.
/*.png
/*.jpeg
/*.jpg

# ─── OS / editor ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
*.swp
